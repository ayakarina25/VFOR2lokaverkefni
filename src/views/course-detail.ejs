<%- include('partials/header', { title: course.title }) %>

<section class="featured">
    <div class="detail-container">
        <h2><%= course.title %></h2>
        <img src="<%= course.image_url %>" alt="<%= course.title %>" class="detail-img">
        <p class="detail-meta"><strong>Instructor:</strong> <%= course.instructor %></p>
        <p class="detail-meta"><strong>Duration:</strong> <%= course.time_hours %> hours</p>
        
        <div class="detail-image"></div>
        
        <p class="detail-price"><strong>Price:</strong> $<%= course.price %></p>
        <p><strong>Description:</strong></p>
        <p><%= course.description %></p>
        
        <div class="detail-buttons">
            <a href="/courses" class="btn-secondary">Back to Courses</a>
            <a href="#" class="btn-primary">Enroll Now</a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>