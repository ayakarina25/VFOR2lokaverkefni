<%- include('partials/header', { title: 'Home' }) %>

<section class="hero-section">
    <div class="hero-content">
        <h2>Welcome to CourseHub</h2>
        <p>Explore courses and learn new skills easily.</p>
        <a href="/courses" class="btn-primary">Browse Courses</a>
    </div>
</section>

<section class="featured">
    <h3>Popular Courses</h3>
    <div class="card-grid">
        <% if (popularCourses && popularCourses.length) { %>
            <% popularCourses.forEach(course => { %>
                <div class="course-card">
                    <div class="card-info">
                        <h4><%= course.title %></h4>
                        <p><%= course.description.substring(0, 60) %>...</p>
                        <p><strong>Instructor:</strong> <%= course.instructor %></p>
                        <p><strong>$<%= course.price %></strong></p>
                        <a href="/courses/<%= course.id %>" class="btn-small">View Course</a>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <p>No popular courses available at the moment.</p>
        <% } %>
    </div>
</section>

<%- include('partials/footer') %>