<%- include('partials/header', { title: 'Home' }) %>

<section class="hero-section">
    <div class="hero-content">
        <h2>Welcome to CourseHub</h2>
        <p>Explore courses and learn new skills easily.</p>
        <a href="/courses" class="btn-primary">Browse Courses</a>
    </div>
</section>

<section class="featured">
    <h3>Courses</h3>
    <div class="card-grid">
        <% if (courses && courses.length > 0) { %>
            <% courses.forEach(course => { %>
                <div class="course-card">
                    <div class="card-img placeholder-img"></div>
                    <div class="card-info">
                        <h4><%= course.title %></h4>
                        <p><%= course.description ? course.description.substring(0, 60) : 'No description' %>...</p>
                        <p><strong>Instructor:</strong> <%= course.instructor %></p>
                        <p><strong>Price:</strong> $<%= course.price %></p>
                        <a href="/courses/<%= course.id %>" class="btn-details">View Details →</a>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="course-card">
                <div class="card-info">
                    <h4>No courses found</h4>
                    <p>Add courses to the database.</p>
                </div>
            </div>
        <% } %>
    </div>
</section>

<%- include('partials/footer') %>